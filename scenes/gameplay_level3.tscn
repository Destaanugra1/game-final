[sub_resource type="RectangleShape2D" id="RectRiver"]
size = Vector2(4200, 80)

[sub_resource type="Shader" id="ShaderWater"]
code = "shader_type canvas_item;

uniform vec4 water_color : source_color = vec4(0.12, 0.45, 0.65, 0.85);
uniform float speed = 1.0;
uniform float wave_strength = 0.02;

void fragment() {
    vec2 uv = UV;
    uv.x += sin(uv.y * 20.0 + TIME * speed) * wave_strength;
    COLOR = water_color;
    // Highlight at the top
    if (uv.y < 0.08 + sin(uv.x * 15.0 + TIME * 1.5) * 0.02) {
        COLOR.rgb += vec3(0.25);
    }
}
"

